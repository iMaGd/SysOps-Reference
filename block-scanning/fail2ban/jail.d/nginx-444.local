[nginx-444]
enabled  = true
filter   = nginx-444
backend  = auto
port     = http,https

ignoreip = 127.0.0.1/8 ::1 0.0.0.0

logpath  =
    /var/log/nginx/*.log
    /srv/users/*/log/*/*_nginx.access*.log

findtime = 1m
maxretry = 20
bantime  = 10m
bantime.increment = true
bantime.factor = 2
bantime.maxtime = 2w

# action = iptables[name=nginx-444, port="http,https"]
action = nftables[name=nginx-444, port="http,https"]